ENV=development
LOG_LEVEL=DEBUG
# 日志输出配置：
# - all：输出全部日志（项目 + 系统/框架）
# - 其他值：按逗号分隔为 logger 前缀白名单，仅输出命中的日志
# 使用示例：
#   1) LOG_OUTPUT_MODE=all
#   2) LOG_OUTPUT_MODE=app,core,__main__
#   3) LOG_OUTPUT_MODE=app,sqlalchemy.engine.Engine
LOG_OUTPUT_MODE=all
APP_CONFIG_FILEPATH=config.yaml
AUTO_RUN_DB_MIGRATIONS=true
AGENT_RUNTIME_ENGINE=langgraph
DB_MIGRATION_LOG_INTERVAL_SECONDS=3

# Embedding 配置
EMBEDDING_BASE_URL=https://api.openai.com/v1
EMBEDDING_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small
# 可选：指定返回向量维度。
# 作用：
# 1. 需要压缩向量长度、降低存储成本时可显式设置；
# 2. 数据库向量列维度固定时，必须与库表维度一致；
# 3. 若供应商/模型不支持自定义维度，留空即可，由模型返回默认维度。
# 示例：1536、1024、768
EMBEDDING_DIMENSIONS=

# CORS 配置
# 开发模式示例：本地前端地址（localhost/127.0.0.1）。
# 生产模式要求：替换为正式前端域名（如 https://app.example.com），禁止使用 "*"。
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# 认证会话已采用 HttpOnly Cookie，前端跨端口直连后端时需开启。
# 注意：为 true 时，CORS_ALLOWED_ORIGINS 必须是显式白名单，不能包含 "*"。
CORS_ALLOW_CREDENTIALS=true

# SQLAlchemy数据库配置
SQLALCHEMY_DATABASE_URI=postgresql+asyncpg://postgres:postgres@127.0.0.1:5432/actus

# Redis数据库配置
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# 认证配置
# 生产环境务必替换为随机高强度密钥
AUTH_JWT_SECRET=change-this-to-a-secure-random-secret
AUTH_JWT_ALGORITHM=HS256
AUTH_ACCESS_TOKEN_EXPIRES_IN=1800
AUTH_REFRESH_TOKEN_EXPIRES_IN=604800
AUTH_REGISTER_CODE_EXPIRES_IN=300
AUTH_REGISTER_CODE_LENGTH=6
AUTH_LOGIN_RATE_LIMIT_MAX_ATTEMPTS=10
AUTH_LOGIN_RATE_LIMIT_WINDOW_SECONDS=300
AUTH_SEND_CODE_RATE_LIMIT_MAX_ATTEMPTS=10
AUTH_SEND_CODE_RATE_LIMIT_WINDOW_SECONDS=300
# 认证接口是否强制 HTTPS（本地开发可 false，测试/生产建议 true）
AUTH_REQUIRE_HTTPS=false
AUTH_COOKIE_NAME=actus_refresh_token
AUTH_COOKIE_DOMAIN=
AUTH_COOKIE_PATH=/api/auth
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_HTTP_ONLY=true
AUTH_COOKIE_SAMESITE=lax

# 邮件服务配置（生产环境验证码发送使用，默认先留空）
SMTP_HOST=
SMTP_PORT=587
SMTP_FROM_EMAIL=
SMTP_PASSWORD=
SMTP_USE_TLS=true


# 腾讯云COS对象存储
COS_SECRET_ID=
COS_SECRET_KEY=
COS_REGION=
COS_SCHEMA=
COS_BUCKET=
COS_DOMAIN=

# 沙箱配置
SANDBOX_ADDRESS=
SANDBOX_IMAGE=actus-sandbox
SANDBOX_NAME_PREFIX=actus-sandbox
SANDBOX_TTL_MINUTES=60
SANDBOX_NETWORK=actus-network
SANDBOX_CHROME_ARGS=
SANDBOX_HTTPS_PROXY=
SANDBOX_HTTP_PROXY=
SANDBOX_NO_PROXY=
