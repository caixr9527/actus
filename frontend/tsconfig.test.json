{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "outDir": ".tmp-tests",
    "rootDir": ".",
    "module": "commonjs",
    "moduleResolution": "node",
    "target": "ES2020",
    "types": ["node"],
    "incremental": false,
    "declaration": false,
    "sourceMap": false
  },
  "include": [
    "src/lib/api/fetch.ts",
    "src/lib/api/file.ts",
    "src/lib/auth/**/*.ts",
    "src/lib/guest-auth-draft.ts",
    "src/lib/session-stream-policy.ts",
    "src/lib/session-detail-runtime.ts",
    "src/lib/session-events.ts",
    "src/lib/api/types.ts",
    "tests/**/*.test.ts"
  ]
}
